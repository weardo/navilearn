# NaviLearn environment template. Copy to .env and fill in real values.
# Never commit a real .env. All values below are placeholders.

# LLM routing (litellm). Provider + primary model.
LLM_PROVIDER=groq
LLM_MODEL=llama-3.1-8b-instant

# Groq API (primary LLM backend).
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Comma-separated litellm fallback models tried if the primary fails.
LLM_FALLBACK_MODELS=groq/llama-3.3-70b-versatile,groq/openai/gpt-oss-20b

# Embeddings (fastembed downloads this model on first use).
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Local Chroma persistence dir (used only when VECTOR_BACKEND is not supabase).
CHROMA_DIR=.chroma

# Retrieval fan-out (top-k chunks).
TOP_K=4

# Sarvam API (Indic speech/translation features).
SARVAM_API_KEY=sk_your_sarvam_api_key_here

# Supabase project.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_DB_PASSWORD=your_supabase_db_password_here

# Storage backends: "supabase" for hosted, else local.
DB_BACKEND=supabase
VECTOR_BACKEND=supabase

# Co-solve host code runner. Keep false in public deployments.
NAVI_ENABLE_CODE_RUN=false
